# ==========================================
# GYM MANAGEMENT SYSTEM — ENVIRONMENT CONFIG
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ==========================================

# ----- SERVER -----
PORT=5000
NODE_ENV=production

# ----- DATABASE (use RDS endpoint on AWS) -----
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_USER=gym_user
DB_PASSWORD=your_strong_password_here
DB_NAME=rr_gym

# ----- JWT (generate a long random string) -----
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_string

# ----- CORS (your deployed frontend URL) -----
# Multiple origins: FRONTEND_URL=https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ----- BASE URL (for chatbot HTTP-Referer header) -----
BASE_URL=https://yourdomain.com

# ----- EMAIL (Gmail App Password — NOT your Gmail login password) -----
# Enable 2FA on Gmail, then create App Password at: myaccount.google.com/apppasswords
EMAIL=yourgym@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_16_chars

# ----- SMS (Fast2SMS API key) -----
FAST2SMS_API_KEY=your_fast2sms_api_key

# ----- AI CHATBOT (OpenRouter API key) -----
OPENROUTER_API_KEY=your_openrouter_api_key
